{
  "manifest_version": 3,
  "name": "Peekaboo",
  "version": "1.0",
  "description": "Your witty browser companion.",

  "permissions": [
    "tabs",
    "history",
    "storage",
    "alarms",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]

}